{
  "manifest_version": 3,
  "name": "WebChat Overlay",
  "version": "2.2.0",
  "description": "Injects a minimal floating chat widget into webpages.",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
